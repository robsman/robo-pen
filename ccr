#!/usr/bin/env zsh
# ccr — Claude Container Runner
# Wrapper to run claude-container just recipes from anywhere.

set -euo pipefail

# Set this to wherever you cloned claude-container, or override with the
# environment variable CLAUDE_CONTAINER_DIR.
CLAUDE_CONTAINER_DIR="${CLAUDE_CONTAINER_DIR:-$HOME/repos/claude-container}"

if [[ ! -f "$CLAUDE_CONTAINER_DIR/Justfile" ]]; then
    echo "Error: claude-container not found at $CLAUDE_CONTAINER_DIR" >&2
    echo "Set CLAUDE_CONTAINER_DIR to the correct path." >&2
    exit 1
fi

if [[ $# -eq 0 ]]; then
    echo "Usage: ccr <recipe> [args...]"
    echo ""
    echo "Examples (cwd-anchored — container name defaults to basename of \$PWD):"
    echo "  cd ~/my-repo && ccr claude       Auto-create/start container for this dir"
    echo "  ccr shell                        Open a shell into the cwd container"
    echo "  ccr login                        Authenticate Claude in the cwd container"
    echo "  ccr destroy                      Remove the cwd container"
    echo ""
    echo "Explicit name still works (overrides cwd-based default):"
    echo "  ccr build                        Build the container image"
    echo "  ccr create my-project            Create a container named claude-my-project"
    echo "  ccr claude my-project \"prompt\"    Run Claude with a prompt"
    echo "  ccr claude-safe my-project       Start Claude in safe mode"
    echo "  ccr list                         List all containers + their workspaces"
    echo "  ccr stats                        Show resource usage"
    echo ""
    echo "Run 'ccr --recipes' to see all available recipes."
    exit 0
fi

if [[ "$1" == "--recipes" ]]; then
    just --justfile "$CLAUDE_CONTAINER_DIR/Justfile" --list
    exit 0
fi

# `ccr lint` runs the host-side ccr-fuse binary against the .ccr/shadow in the
# caller's cwd. No container start required.
if [[ "$1" == "lint" ]]; then
    shift
    HOST_BIN="$CLAUDE_CONTAINER_DIR/ccr-fuse/ccr-fuse-darwin-arm64"
    if [[ ! -x "$HOST_BIN" ]]; then
        echo "ccr lint: host binary missing at $HOST_BIN" >&2
        echo "Run 'ccr build-host' to cross-build it (one-time setup)." >&2
        exit 1
    fi
    # Pass --repo-dir so lint can resolve the agent profile bundle (built-ins
    # live under $CLAUDE_CONTAINER_DIR/agent.profiles/). Skipped if the user
    # already supplied --repo-dir or an explicit shadow path.
    if ! printf '%s\n' "$@" | grep -q -e '--repo-dir'; then
        set -- --repo-dir "$CLAUDE_CONTAINER_DIR" "$@"
    fi
    exec "$HOST_BIN" lint "$@"
fi

# Note: --working-directory is intentionally NOT set, so that just's
# `invocation_directory()` returns the caller's actual cwd, enabling
# cwd-anchored container mounts.
exec just --justfile "$CLAUDE_CONTAINER_DIR/Justfile" "$@"
